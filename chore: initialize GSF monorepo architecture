eventRewardJob.js (baru):

import { Event, EventFeedback, EventRewardHistory } from "../models/index.js";
import { Op } from "sequelize";

export const eventRewardJob = async () => {
  const finishedEvents = await Event.findAll({ where: { status: "finished" } });
  for (const ev of finishedEvents) {
    const feedbacks = await EventFeedback.findAll({
      where: { eventId: ev.id },
      order: [["createdAt", "ASC"]],
    });
    if (!feedbacks.length) continue;

    const top = feedbacks.reduce((a, b) =>
      a.feedbackText.length > b.feedbackText.length ? a : b
    );
    await EventRewardHistory.create({
      userId: top.userId,
      eventId: ev.id,
      rewardType: "badge",
      rewardMeta: { name: "Top Feedback", points: 50 },
    });
  }
};




