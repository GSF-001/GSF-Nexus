      <div className="bg-gray-900 p-6 rounded-xl w-96">  
        <h2 className="text-xl font-bold text-cyan-400 mb-2">Feedback Event</h2>  
        <textarea  
          value={text}  
          onChange={(e) => setText(e.target.value)}  
          placeholder="Apa yang kurang / harus ditambah?"  
          className="w-full h-24 p-2 rounded mb-2 bg-gray-800 text-gray-100"  
        />  
        <input  
          type="number"  
          value={rating}  
          onChange={(e) => setRating(e.target.value)}  
          placeholder="Rating 1-5"  
          className="w-16 p-1 rounded bg-gray-800 text-gray-100 mb-4"  
        />  
        <div className="flex justify-end gap-2">  
          <button onClick={onClose} className="px-4 py-2 bg-gray-700 rounded">Cancel</button>  
          <button onClick={submit} className="px-4 py-2 bg-cyan-500 rounded">Submit</button>  
        </div>  
      </div>  
    </div>  
  );  
}  
  
  
