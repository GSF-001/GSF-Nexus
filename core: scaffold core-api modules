const QR_CODES = [];

export const generateQR = (tier) => {
  const prefix = {
    EXCL: "EXCL",
    MED: "MED",
    RET: "RET"
  }[tier];

  const code = `${prefix}-${Math.random().toString(36).slice(2, 10)}`;

  const qr = {
    code,
    tier,
    status: "ACTIVE",
    expiredAt: Date.now() + 86400000
  };

  QR_CODES.push(qr);
  return qr;
};

export const validateQR = (code) => {
  const qr = QR_CODES.find(q => q.code === code);

  if (!qr) throw new Error("Invalid QR");
  if (qr.status !== "ACTIVE") throw new Error("Used");
  if (Date.now() > qr.expiredAt) throw new Error("Expired");

  qr.status = "USED";
  qr.usedAt = new Date();

  return qr;
};


