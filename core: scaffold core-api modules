import { recordLedger } from "./ledger.engine.js";

const WALLETS = [];

export const createWallet = (userId) => {
  const wallet = { userId, balance: 0 };
  WALLETS.push(wallet);
  return wallet;
};

export const credit = (userId, amount, source) => {
  const wallet = WALLETS.find(w => w.userId === userId);
  wallet.balance += amount;

  recordLedger({
    userId,
    type: "CREDIT",
    amount,
    source
  });

  return wallet;
};


