export const dispatchCityAI = ({ action, payload }) => {
  switch (action) {
    case ACTIONS.TRANSACTION:
      return { result: "FLS_APPROVED" };

    case ACTIONS.USER_REPORT:
      return { result: "POLICE_INVESTIGATING" };

    case ACTIONS.COMMUNITY_MOOD:
      return { mood: "STABLE" };

    case ACTIONS.POLICY_UPDATE:
      return { decision: "AUTO_ADJUSTED" };

    default:
      return { status: "NO_ACTION" };
  }
};


